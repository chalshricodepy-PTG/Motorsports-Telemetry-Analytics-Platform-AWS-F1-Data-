{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RunECSTask",
      "Effect": "Allow",
      "Action": ["ecs:RunTask"],
      "Resource": "*"
    },
    {
      "Sid": "PassRoleToECS",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "*",
      "Condition": {
        "StringLike": {
          "iam:PassedToService": "ecs-tasks.amazonaws.com"
        }
      }
    }
  ]
}
